    </div>

    <p id=3D"regError" class=3D"form-error"></p>
    <button type=3D"button" class=3D"btn-generate" onclick=3D"saveProfile()=
"
data-i18n=3D"reg.save">Profil speichern & weiter</button>
  </div>

  <!-- =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D EINSTELLUNGEN =3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D -->
  <div id=3D"plannerView" class=3D"hidden">
    <button type=3D"button" class=3D"football-btn" title=3D"Profil =C3=A4nd=
ern"
aria-label=3D"Profil =C3=A4ndern" onclick=3D"editProfile()">=E2=9A=BD</butt=
on>
    <header>
      <h1 data-i18n=3D"pl.title">=E2=9A=BD Football Coach</h1>
      <p data-i18n=3D"pl.sub">Erstelle deinen personalisierten
Fu=C3=9Fball-Trainingsplan</p>
    </header>

    <div class=3D"profile-bar" id=3D"profileInfo"></div>

    <form id=3D"planForm">
      <!-- Nur-Torwart-=C3=9Cbungen -->
      <label class=3D"switch-row" id=3D"gkRow" for=3D"gkOnly">
        <span class=3D"switch-txt">
          <b data-i18n=3D"pl.gkTitle">Nur Torwart-=C3=9Cbungen</b>
          <span data-i18n=3D"pl.gkSub">Alle Trainingstage bestehen
ausschlie=C3=9Flich aus Torwart-=C3=9Cbungen.</span>
        </span>
        <span class=3D"tswitch"><input type=3D"checkbox" id=3D"gkOnly"
onchange=3D"onGkToggle()"><i></i></span>
      </label>

      <div class=3D"form-group">
        <label class=3D"field-label" data-i18n=3D"pl.focus">Trainingsfokus
(Mehrfachauswahl m=C3=B6glich)</label>
        <div class=3D"focus-grid" id=3D"focusGrid"></div>
        <div class=3D"hint" data-i18n=3D"pl.focusHint">W=C3=A4hle einen ode=
r mehrere
Schwerpunkte =E2=80=93 die Einheiten werden auf deine Auswahl verteilt.</di=
v>
