function calcAge(dobStr){
 if(!dobStr) return null;
 const dob=3Dnew Date(dobStr); if(isNaN(dob)) return null;
 const now=3Dnew Date();
 let age=3Dnow.getFullYear()-dob.getFullYear();
 const m=3Dnow.getMonth()-dob.getMonth();
 if(m<0 || (m=3D=3D=3D0 && now.getDate()<dob.getDate())) age--;
 return (age>=3D0 && age<=3D120)? age : null;
}

