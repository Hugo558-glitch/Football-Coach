/* =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
   =C3=9CBUNGS-AUSWAHL & "USED"-TRACKING (neue =C3=9Cbungen bei Neugenerier=
ung)
   =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D */
function usedGet(){ try{ const raw=3DLS.get(USED_KEY); return
raw?JSON.parse(raw):{}; }catch(e){ return {}; } }
function usedSet(o){ LS.set(USED_KEY, JSON.stringify(o)); }
function exKey(poolId, ex){ return poolId + "::" + (ex.n && ex.n.de ?
ex.n.de : L(ex.n)); }

/* W=C3=A4hlt count =C3=9Cbungen aus pool, bevorzugt noch nicht (k=C3=BCrzl=
ich) genutzte.
   Sobald alle genutzt wurden, wird der Pool zur=C3=BCckgesetzt =E2=86=92 e=
chte
Rotation. */
function pickFresh(poolId, pool, count){
 if(!pool || !pool.length) return [];
 const used=3DusedGet();
 let seen =3D used[poolId] || [];
 const avail =3D pool.filter(ex=3D> !seen.includes(exKey(poolId,ex)) );
 let chosen=3D[];
 let source =3D avail.length>=3Dcount ? avail : null;
 if(source){
   chosen =3D shuffle(avail).slice(0,count);
 } else {
   // Nicht genug frische =C3=BCbrig =E2=86=92 Rest nehmen, dann Pool zur=
=C3=BCcksetzen und
auff=C3=BCllen
   chosen =3D shuffle(avail).slice();
   const remaining =3D shuffle(pool.filter(ex=3D>!chosen.includes(ex)));
   while(chosen.length<count && remaining.length){
chosen.push(remaining.shift()); }
   seen =3D []; // Rotation neu starten
 }
 const newSeen =3D seen.concat(chosen.map(ex=3D>exKey(poolId,ex)));
 // Begrenzen, damit der Speicher nicht unbegrenzt w=C3=A4chst
 used[poolId] =3D newSeen.slice(-Math.max(pool.length, count*3));
 usedSet(used);
 return chosen;
}

/* =C3=9Cbung sprachlich + materialabh=C3=A4ngig aufl=C3=B6sen */
function resolveExercise(ex, material, partner){
 let name =3D L(ex.n);
 let desc =3D L(ex.d);
 let video =3D ex.v ? L(ex.v) : null;
 const req =3D ex.req || "frei";

 // Material-Anpassung
 if(material=3D=3D=3D"koerper" && (req=3D=3D=3D"ball"||req=3D=3D=3D"extra")=
 && ex.kg){
   name =3D ex.kg.n ? L(ex.kg.n) : name;
   desc =3D ex.kg.d ? L(ex.kg.d) : desc;
 } else if(material=3D=3D=3D"ball_tor" && req=3D=3D=3D"extra" && ex.bt){
   name =3D ex.bt.de ? L(ex.bt) : (ex.bt.n ? L(ex.bt.n) : name);
 }

 // Partner-Variante (falls vorhanden und mit Partner trainiert wird)
 let withPartner=3Dfalse;
 if(partner=3D=3D=3D"partner" && ex.pa){
   name =3D (ex.pa.de)? L(ex.pa) : (ex.pa.n? L(ex.pa.n): name);
   withPartner=3Dtrue;
 }
 return {name,desc,video,withPartner,gk:!!ex._gk};
}

