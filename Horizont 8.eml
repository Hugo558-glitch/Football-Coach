      <div class=3D"form-group">
        <label class=3D"field-label" for=3D"status"
data-i18n=3D"pl.status">Aktueller Fitness-Status</label>
        <select id=3D"status">
          <option value=3D"fit" data-i18n=3D"st.fit">Voll einsatzbereit &
fit</option>
          <option value=3D"injury" data-i18n=3D"st.inj">Aufbautraining nach
Verletzung</option>
