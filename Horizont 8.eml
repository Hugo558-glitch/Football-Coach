      </div>

      <div class=3D"form-group">
        <label class=3D"field-label" for=3D"level"
data-i18n=3D"pl.level">Aktuelles Leistungsniveau</label>
        <select id=3D"level"></select>
      </div>

      <div class=3D"form-group">
        <label class=3D"field-label" for=3D"partner"
data-i18n=3D"pl.partner">Trainierst du allein oder mit Partner?</label>
        <select id=3D"partner">
          <option value=3D"allein" data-i18n=3D"pa.solo">Allein</option>
          <option value=3D"partner" data-i18n=3D"pa.partner">Mit Partner / =
zu
zweit</option>
        </select>
      </div>

      <div class=3D"form-group">
        <label class=3D"field-label" for=3D"material"
data-i18n=3D"pl.material">Trainingsmaterial</label>
        <select id=3D"material">
          <option value=3D"ball_tor" data-i18n=3D"mat.bt">Mit Ball und
Tor</option>
          <option value=3D"voll" data-i18n=3D"mat.voll">Mit weiteren
Trainingsmaterialien (H=C3=BCtchen, Leiter, B=C3=A4nder ...)</option>
          <option value=3D"koerper" data-i18n=3D"mat.kg">Nur eigenes
K=C3=B6rpergewicht (kein Ball)</option>
        </select>
        <div class=3D"hint" data-i18n=3D"pl.matHint">Die =C3=9Cbungen werde=
n
automatisch an dein verf=C3=BCgbares Material angepasst.</div>
      </div>

      <div class=3D"form-group">
        <label class=3D"field-label" data-i18n=3D"pl.days">An welchen Tagen
m=C3=B6chtest du trainieren?</label>
        <div class=3D"weekday-grid" id=3D"weekdayGrid"></div>
        <div class=3D"hint" data-i18n=3D"pl.daysHint">Tippe die Trainingsta=
ge
an =E2=80=93 die Regenerationstage werden automatisch auf die restlichen Ta=
ge
gelegt.</div>
      </div>

      <p id=3D"planError" class=3D"form-error"></p>
      <button type=3D"button" class=3D"btn-generate" onclick=3D"generatePla=
n()"
data-i18n=3D"pl.gen">Plan generieren</button>
    </form>
  </div>

  <!-- =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D PLAN-SEITE =3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D -->
  <div id=3D"planView" class=3D"hidden">
    <button type=3D"button" class=3D"football-btn" title=3D"Profil =C3=A4nd=
ern"
aria-label=3D"Profil =C3=A4ndern" onclick=3D"editProfile()">=E2=9A=BD</butt=
on>
    <header>
      <h1 data-i18n=3D"plan.title">=E2=9A=BD Dein Trainingsplan</h1>
      <p id=3D"planSubtitle"></p>
    </header>

    <div id=3D"ageNotice"></div>
    <div id=3D"injuryNotice"></div>
    <div class=3D"plan-header" id=3D"planMeta"></div>
    <div id=3D"positionNotice"></div>
    <div id=3D"planDays"></div>

    <div class=3D"btn-row">
      <button type=3D"button" class=3D"btn-secondary" onclick=3D"goToSettin=
gs()"
data-i18n=3D"plan.back">=E2=86=90 Optionen neu ausw=C3=A4hlen</button>
      <button type=3D"button" class=3D"btn-generate" onclick=3D"generatePla=
n()"
data-i18n=3D"plan.regen">=F0=9F=94=84 Neu generieren</button>
    </div>
  </div>

</div>

<script>
/* =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D
   BASIS: Speicher (mit Fallback, falls localStorage nicht verf=C3=BCgbar i=
