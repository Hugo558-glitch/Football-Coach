<!DOCTYPE html>
<html lang=3D"de">
<head>
<meta charset=3D"UTF-8">
<meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=3D1.=
0">
<title>Football Coach - Trainingsplaner</title>
<style>
:root{
  --primary-color:#2e7d32;
  --primary-hover:#1b5e20;
  --dark-bg:#121212;
  --card-bg:#1e1e1e;
  --text-color:#ffffff;
  --text-muted:#aaaaaa;
  --accent-color:#00e676;
  --warning-color:#ff9100;
  --info-color:#29b6f6;
  --purple:#b388ff;
  --dark-green:#2e8b3d;
  --light-green:#8df0a8;
}
*{box-sizing:border-box;margin:0;padding:0;font-family:'Segoe
UI',Tahoma,Geneva,Verdana,sans-serif;}
body{background-color:var(--dark-bg);color:var(--text-color);padding:20px;d=
isplay:flex;justify-content:center;align-items:flex-start;min-height:100vh;=
}
.app-container{width:100%;max-width:700px;background-color:var(--card-bg);p=
adding:30px;border-radius:15px;box-shadow:0
8px 24px rgba(0,0,0,.5);border-top:5px solid
var(--primary-color);position:relative;}
header{text-align:center;margin-bottom:25px;padding-top:8px;}
header h1{font-size:24px;color:var(--accent-color);margin-bottom:5px;}
header p{color:var(--text-muted);font-size:14px;}
.form-group{margin-bottom:18px;}
label.field-label{display:block;margin-bottom:8px;font-weight:600;font-size=
:14px;}
.hint{font-weight:400;color:var(--text-muted);font-size:12px;margin-top:4px=
;}
select,input[type=3Dtext],input[type=3Ddate]{width:100%;padding:12px;backgr=
ound-color:#2a2a2a;border:1px
solid
#444;border-radius:8px;color:#fff;font-size:16px;outline:none;transition:bo=
rder-color
.3s;}
select:focus,input:focus{border-color:var(--accent-color);}
button.btn-generate{width:100%;padding:14px;background-color:var(--primary-=
color);color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:=
bold;cursor:pointer;transition:background-color
.3s,transform .1s;margin-top:6px;}
button.btn-generate:hover{background-color:var(--primary-hover);}
button.btn-generate:active{transform:scale(.98);}
.btn-secondary{padding:12px;background:#2a2a2a;color:#fff;border:1px solid
#444;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;transi=
tion:background-color
.2s;}
.btn-secondary:hover{background:#383838;}
.btn-row{display:flex;gap:12px;margin-top:8px;}
.btn-row .btn-secondary{flex:1;}
.btn-row .btn-generate{flex:1;margin-top:0;}

/* Fu=C3=9Fball-Button (Profil =C3=A4ndern) oben rechts =E2=80=93 ohne Scha=
tten */
.football-btn{position:absolute;top:18px;right:18px;width:46px;height:46px;=
border-radius:50%;border:2px
solid var(--accent-color);background:#0d0d0d radial-gradient(circle at 50%
40%, #fafafa 0 9px, transparent
10px);display:flex;align-items:center;justify-content:center;font-size:24px=
;cursor:pointer;transition:transform
.15s;line-height:1;padding:0;z-index:20;}
.football-btn:hover{transform:rotate(20deg) scale(1.08);}
.football-btn:active{transform:scale(.92);}

/* Zahnrad (Design-Einstellungen) oben links */
.gear-btn{position:absolute;top:18px;left:18px;width:46px;height:46px;borde=
r-radius:50%;border:2px
solid
#555;background:#0d0d0d;color:#ddd;display:flex;align-items:center;justify-=
content:center;font-size:23px;cursor:pointer;transition:transform
.2s,border-color .2s;line-height:1;padding:0;z-index:20;}
.gear-btn:hover{transform:rotate(45deg);border-color:var(--accent-color);}
.gear-btn:active{transform:scale(.92);}

/* Design-Panel */
.design-panel{display:none;position:absolute;top:72px;left:18px;right:18px;=
background:#181818;border:1px
solid #333;border-radius:12px;padding:16px;z-index:40;box-shadow:0 12px
30px rgba(0,0,0,.6);}
.design-panel.open{display:block;}
.dp-title{display:flex;justify-content:space-between;align-items:center;fon=
t-weight:700;font-size:15px;margin-bottom:12px;color:var(--accent-color);}
.dp-close{background:none;border:none;color:#888;font-size:18px;cursor:poin=
ter;padding:2px
6px;}
.dp-close:hover{color:#fff;}
.dp-group{margin-bottom:14px;}
.dp-group
h4{font-size:11px;color:var(--text-muted);margin-bottom:8px;text-transform:=
uppercase;letter-spacing:.06em;font-weight:700;}
.swatches{display:flex;flex-wrap:wrap;gap:8px;}
.swatch{width:46px;height:46px;border-radius:8px;border:2px solid
#444;cursor:pointer;background-size:cover;background-position:center;paddin=
g:0;}
.swatch:hover{border-color:#888;}
.swatch.active{border-color:var(--accent-color);}
.lang-row{display:flex;gap:8px;flex-wrap:wrap;}
.lang-chip{padding:7px 16px;border-radius:999px;border:1px solid
#444;background:#2a2a2a;color:#fff;cursor:pointer;font-weight:700;font-size=
:13px;transition:.15s;}
.lang-chip.active{border-color:var(--accent-color);background:#153524;color=
:var(--accent-color);}

.profile-bar{background:#2a2a2a;padding:12px
15px;border-radius:8px;margin-bottom:22px;border-left:4px solid
var(--accent-color);font-size:14px;line-height:1.5;}
.profile-bar strong{color:var(--accent-color);}

/* Nur-Torwart-Schalter */
.switch-row{display:flex;justify-content:space-between;align-items:center;g=
ap:12px;background:#2a2a2a;border:1px
solid #444;border-radius:8px;padding:12px
14px;margin-bottom:18px;cursor:pointer;}
.switch-row.on{border-color:var(--info-color);background:#10222e;}
.switch-txt b{display:block;font-size:14px;margin-bottom:2px;}
.switch-txt span{font-size:12px;color:var(--text-muted);line-height:1.4;}
.tswitch{position:relative;width:48px;height:26px;flex:none;}
.tswitch input{opacity:0;width:0;height:0;}
.tswitch
i{position:absolute;inset:0;background:#555;border-radius:999px;cursor:poin=
ter;transition:.2s;}
.tswitch
i:before{content:"";position:absolute;width:20px;height:20px;left:3px;top:3=
px;background:#fff;border-radius:50%;transition:.2s;}
.tswitch input:checked + i{background:var(--info-color);}
.tswitch input:checked + i:before{transform:translateX(22px);}
.tswitch input:focus + i{box-shadow:0 0 0 3px rgba(41,182,246,.3);}

/* Fokus-Checkboxen */
.focus-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px=
,1fr));gap:10px;}
.focus-option{display:flex;align-items:center;gap:10px;background:#2a2a2a;b=
order:1px
solid #444;border-radius:8px;padding:11px
12px;cursor:pointer;font-size:14px;transition:border-color
.2s,background-color .2s;}
.focus-option:hover{border-color:#666;}
.focus-option
input{width:18px;height:18px;accent-color:var(--accent-color);cursor:pointe=
r;flex:none;}
.focus-option.checked{border-color:var(--accent-color);background:#22331f;}

/* Wochentags-Kalender */
.weekday-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;}
.wd{border:1px solid #444;background:#2a2a2a;border-radius:8px;padding:11px
2px;text-align:center;font-size:13px;font-weight:600;cursor:pointer;user-se=
lect:none;transition:.15s;}
.wd:hover{border-color:#777;}
.wd.on{border-color:var(--accent-color);background:#173a26;color:var(--acce=
nt-color);}

.result-container{display:none;}
.result-container.active{display:block;}
.result-container h2{font-size:20px;margin-bottom:16px;}
/* Zusammenfassung der gew=C3=A4hlten Optionen =E2=80=93 gr=C3=BCn */
.plan-header{background:rgba(46,139,61,.16);padding:15px;border-radius:8px;=
margin-bottom:18px;border-left:4px
solid var(--light-green);font-size:14px;line-height:1.7;color:#e2f6e8;}
.plan-header strong{color:var(--light-green);}
.position-box{background-color:rgba(41,182,246,.12);border:1px solid
var(--info-color);color:#cdeafd;padding:13px
15px;border-radius:8px;margin-bottom:18px;font-size:13px;line-height:1.6;}
.position-box strong{color:#4fc3f7;}
.position-box .pos-item{margin-bottom:8px;}
.position-box .pos-item:last-child{margin-bottom:0;}
.age-box{background-color:rgba(179,136,255,.12);border:1px solid
var(--purple);color:#e3d6ff;padding:13px
15px;border-radius:8px;margin-bottom:18px;font-size:13px;line-height:1.6;}
.age-box strong{color:#cbb2ff;}
.injury-warning{background-color:rgba(255,145,0,.15);border:1px solid
var(--warning-color);color:#ffb74d;padding:12px
15px;border-radius:8px;margin-bottom:18px;font-size:13px;line-height:1.6;}
.day-card{background-color:#252525;padding:15px;border-radius:8px;margin-bo=
ttom:14px;}
.day-title{font-weight:bold;color:var(--dark-green);margin-bottom:4px;font-=
size:16px;}
.day-focus{color:var(--light-green);font-size:13px;margin-bottom:12px;}
.exercise-list{list-style:none;}
.exercise-item{font-size:14px;margin-bottom:14px;color:#ddd;padding-left:16=
px;position:relative;}
.exercise-item:last-child{margin-bottom:0;}
.exercise-item::before{content:"\25CF";color:var(--light-green);position:ab=
solute;left:0;top:3px;font-size:10px;}
.exercise-item.gk::before{color:var(--info-color);}
.ex-head{display:flex;justify-content:space-between;align-items:flex-start;=
gap:10px;}
.ex-name{flex:1;font-weight:600;color:#fff;line-height:1.4;}
.ex-tag{font-size:10px;font-weight:700;padding:2px
6px;border-radius:4px;white-space:nowrap;align-self:center;}
.ex-tag.tw{background:rgba(41,182,246,.2);color:#4fc3f7;border:1px solid
var(--info-color);}
.ex-tag.pa{background:rgba(179,136,255,.2);color:#cbb2ff;border:1px solid
var(--purple);}
.ex-desc{color:var(--text-muted);font-size:13px;margin-top:5px;line-height:=
1.55;}
.video-btn{background-color:#3a3a3a;color:#fff;border:none;padding:5px
10px;border-radius:4px;font-size:11px;cursor:pointer;text-decoration:none;w=
hite-space:nowrap;transition:background-color
.2s;align-self:center;}
.video-btn:hover{background-color:#c62828;}
.rest-card{background-color:#252525;padding:13px
15px;border-radius:8px;margin-bottom:14px;border-left:4px solid
var(--warning-color);}
.rest-head{display:flex;justify-content:space-between;align-items:center;ga=
p:10px;}
.rest-title{font-weight:bold;color:var(--warning-color);font-size:14px;}
.rest-text{font-size:13px;color:#aaa;line-height:1.5;margin-top:5px;}
.form-error{color:#ff7043;font-size:13px;margin-bottom:10px;display:none;}
.hidden{display:none;}
@media(max-width:480px){.weekday-grid{gap:4px}.wd{font-size:11px;padding:9p=
x
1px}}
</style>
</head>
<body>

<div class=3D"app-container">

  <!-- Zahnrad: Design-Einstellungen (immer sichtbar) -->
  <button type=3D"button" class=3D"gear-btn" id=3D"gearBtn" title=3D"Design=
"
aria-label=3D"Design" onclick=3D"toggleDesign()">=E2=9A=99=EF=B8=8F</button=
>

  <!-- Design-Panel -->
  <div class=3D"design-panel" id=3D"designPanel">
    <div class=3D"dp-title"><span data-i18n=3D"design.title">Design &
Sprache</span><button type=3D"button" class=3D"dp-close"
onclick=3D"toggleDesign(false)">=E2=9C=95</button></div>
    <div id=3D"dpBody"></div>
    <div class=3D"dp-group">
      <h4 data-i18n=3D"design.lang">Sprache / Language</h4>
      <div class=3D"lang-row">
        <button type=3D"button" class=3D"lang-chip" data-lang=3D"de"
onclick=3D"setLang('de')">=F0=9F=87=A9=F0=9F=87=AA Deutsch</button>
        <button type=3D"button" class=3D"lang-chip" data-lang=3D"en"
onclick=3D"setLang('en')">=F0=9F=87=AC=F0=9F=87=A7 English</button>
      </div>
    </div>
  </div>

  <!-- =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D REGISTRIERUNG =3D=3D=3D=3D=3D=
=3D=3D=3D=3D=3D=3D=3D -->
  <div id=3D"registrationView">
    <header>
