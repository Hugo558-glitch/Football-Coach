/* Erzeugt ein SVG-Datenbild einer Formation (Spieler als Punkte auf dem
Platz) */
function formationSVG(item, w, h){
 const rows =3D item.formation;
 const base =3D item.css || "#0e3d1e";
 let dots =3D "";
 const n =3D rows.length;
 rows.forEach((row,ri)=3D>{
  const y =3D ((ri+0.5)/n)*h;
  row.forEach((_,ci)=3D>{
   const x =3D ((ci+0.5)/row.length)*w;
   dots +=3D `<circle cx=3D"${x.toFixed(1)}" cy=3D"${y.toFixed(1)}"
r=3D"${Math.max(3,w*0.05)}" fill=3D"#ffffff" stroke=3D"#0a0a0a"
stroke-width=3D"1"/>`;
  });
 });
 const svg =3D `<svg xmlns=3D'http://www.w3.org/2000/svg' width=3D'${w}'
height=3D'${h}' viewBox=3D'0 0 ${w} ${h}'>`
  + `<rect width=3D'${w}' height=3D'${h}' fill=3D'${base}'/>`
  + `<rect x=3D'1' y=3D'1' width=3D'${w-2}' height=3D'${h-2}' fill=3D'none'
stroke=3D'rgba(255,255,255,.5)' stroke-width=3D'2'/>`
  + `<line x1=3D'0' y1=3D'${h/2}' x2=3D'${w}' y2=3D'${h/2}'
stroke=3D'rgba(255,255,255,.4)' stroke-width=3D'2'/>`
  + `<circle cx=3D'${w/2}' cy=3D'${h/2}' r=3D'${w*0.12}' fill=3D'none'
stroke=3D'rgba(255,255,255,.4)' stroke-width=3D'2'/>`
  + dots + `</svg>`;
 return "data:image/svg+xml;utf8," + encodeURIComponent(svg);
}

function applyBackground(cat,id){
 let item=3Dnull;
 (DESIGNS[cat]||[]).forEach(d=3D>{ if(d.id=3D=3D=3Did) item=3Dd; });
 if(!item){ // Fallback Standard
   document.body.style.background=3D"#121212"; return;
 }
 if(cat=3D=3D=3D"form"){
   const url =3D formationSVG(item, 600, 900);
   document.body.style.background =3D `#0a0a0a url("${url}") center top /
cover no-repeat fixed`;
 } else {
   document.body.style.background =3D item.css + (cat=3D=3D=3D"pitch" ? " f=
ixed" :
"");
   if(cat=3D=3D=3D"pitch"){ document.body.style.backgroundAttachment=3D"fix=
ed"; }
 }
}

