function renderDesignPanel(){
 const cur =3D loadDesign() || {cat:"colors",id:"dark"};
 const groups =3D [
  {cat:"colors", title:t("design.colors")},
  {cat:"grads",  title:t("design.grads")},
  {cat:"pitch",  title:t("design.pitch")},
  {cat:"form",   title:t("design.form")}
 ];
 let html=3D"";
 groups.forEach(g=3D>{
  html +=3D `<div class=3D"dp-group"><h4>${escapeHtml(g.title)}</h4><div
class=3D"swatches">`;
  DESIGNS[g.cat].forEach(d=3D>{
   const active =3D (cur.cat=3D=3D=3Dg.cat && cur.id=3D=3D=3Dd.id) ? " acti=
ve" : "";
   let style=3D"";
   if(g.cat=3D=3D=3D"form"){
     const url =3D formationSVG(d, 80, 120);
     style =3D `background-image:url('${url}');background-size:cover;`;
   } else {
     style =3D `background:${d.css};`;
   }
   const lbl =3D (typeof d.label=3D=3D=3D"object") ? L(d.label) : d.label;
   html +=3D `<button type=3D"button" class=3D"swatch${active}" style=3D"${=
style}"
title=3D"${escapeHtml(lbl)}" aria-label=3D"${escapeHtml(lbl)}"
onclick=3D"chooseDesign('${g.cat}','${d.id}')"></button>`;
  });
  html +=3D `</div></div>`;
 });
 document.getElementById("dpBody").innerHTML =3D html;
}

function chooseDesign(cat,id){
